# Machine-specific files (don't sync)
*.local.json
*.local.md
CLAUDE.local.md
.claude/*.local.*

# Exception: hookify rules ARE meant to sync
!hookify-rules/*.local.md

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log

# Credentials
.env
.credentials.json
**/credentials.json

# Temporary files
tmp/
temp/
