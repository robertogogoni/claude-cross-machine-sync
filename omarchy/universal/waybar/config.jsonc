[
  {
    "name": "laptop",
    "output": "eDP-1",
    "include": ["~/.config/waybar/modules.jsonc"],
    "reload_style_on_change": true,
    "layer": "top",
    "position": "top",
    "spacing": 0,
    "height": 26,
    "modules-left": [
      "custom/omarchy",
      "hyprland/workspaces",
      "wlr/taskbar"
    ],
    "modules-center": [
      "hyprland/window",
      "custom/media",
      "clock",
      "custom/update",
      "custom/voxtype",
      "custom/screenrecording-indicator",
      "custom/idle-indicator",
      "custom/notification-silencing-indicator"
    ],
    "modules-right": [
      "custom/pomodoro",
      "custom/ai-usage",
      "custom/sync-status",
      "group/tray-expander",
      "bluetooth",
      "network",
      "pulseaudio",
      "cpu",
      "battery"
    ]
  },
  {
    "name": "tv",
    "output": "HDMI-A-1",
    "include": ["~/.config/waybar/modules.jsonc"],
    "reload_style_on_change": true,
    "layer": "top",
    "position": "top",
    "spacing": 2,
    "height": 38,
    "modules-left": [
      "custom/omarchy",
      "hyprland/workspaces",
      "wlr/taskbar"
    ],
    "modules-center": [
      "hyprland/window",
      "custom/media",
      "clock",
      "custom/update",
      "custom/voxtype",
      "custom/screenrecording-indicator",
      "custom/idle-indicator",
      "custom/notification-silencing-indicator"
    ],
    "modules-right": [
      "custom/pomodoro",
      "custom/ai-usage",
      "custom/sync-status",
      "group/tray-expander",
      "bluetooth",
      "network",
      "pulseaudio",
      "cpu",
      "battery"
    ]
  }
]
