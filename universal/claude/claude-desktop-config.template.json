{
  "_comment": "Template for Claude Desktop MCP config. Replace ${NODE_PATH} with absolute path to node/npx binary. Updated 2026-04-06.",
  "mcpServers": {
    "obra-superpowers": {
      "command": "${NODE_PATH}/node",
      "args": [
        "${HOME}/obra-superpowers-mcp/index.js"
      ]
    },
    "github": {
      "command": "${NODE_PATH}/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT}"
      }
    },
    "memory": {
      "command": "${NODE_PATH}/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "sequential-thinking": {
      "command": "${NODE_PATH}/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "cortex": {
      "command": "${NODE_PATH}/node",
      "args": [
        "${HOME}/.claude/memory/cortex/server.cjs"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      }
    },
    "hive-toolkit": {
      "command": "${NODE_PATH}/node",
      "args": [
        "${HOME}/repos/hive/plugins/toolkit/dist/index.js"
      ]
    },
    "hive-intel": {
      "command": "${NODE_PATH}/node",
      "args": [
        "${HOME}/repos/hive/plugins/intel/dist/index.js"
      ],
      "env": {
        "VOYAGE_API_KEY": "${VOYAGE_API_KEY}"
      }
    },
    "hive-bridges": {
      "command": "${NODE_PATH}/node",
      "args": [
        "${HOME}/repos/hive/plugins/bridges/dist/index.js"
      ]
    },
    "hive-auto": {
      "command": "${NODE_PATH}/node",
      "args": [
        "${HOME}/repos/hive/plugins/auto/dist/index.js"
      ]
    }
  },
  "preferences": {
    "coworkScheduledTasksEnabled": true,
    "ccdScheduledTasksEnabled": true,
    "sidebarMode": "chat",
    "coworkWebSearchEnabled": true
  }
}
